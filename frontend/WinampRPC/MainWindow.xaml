<Window
    x:Class="WinampRPC.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinampRPC"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WinampRPC">

    <Grid Background="Transparent" RequestedTheme="Dark">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="36" Background="Transparent" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <Image x:Name="TitleBarIcon" Width="16" Height="16" Margin="0,0,12,0"/>
                <TextBlock Text="WinRPC" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Menu Bar -->
            <MenuBar Grid.Row="0" Background="Transparent" VerticalAlignment="Top">
                <MenuBarItem x:Name="FileMenu" Title="File">
                    <MenuFlyoutItem Text="View file info" Click="ViewFileInfo_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Exit" Click="Exit_Click" />
                </MenuBarItem>
                <MenuBarItem x:Name="SettingsMenu" Title="Settings">
                    <MenuFlyoutItem Text="Theme (Toggle Dark/Light)" Click="ThemeToggle_Click" />
                    <MenuFlyoutItem Text="Preferences" Click="Preferences_Click" />
                </MenuBarItem>
                <MenuBarItem x:Name="HelpMenu" Title="Help">
                    <MenuFlyoutItem Text="Help" Click="Help_Click" />
                    <MenuFlyoutItem Text="About WinampRPC v1.0" Click="About_Click" />
                </MenuBarItem>
            </MenuBar>

            <Grid Grid.Row="1" Padding="32" Margin="0,0,0,0" x:Name="LeftContentGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Left Column Container -->
                <Grid Grid.Row="0" Grid.Column="0" x:Name="CardsContainerGrid" SizeChanged="CardsContainer_SizeChanged">
                    <Grid VerticalAlignment="Bottom">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Visualizer -->
                        <Grid x:Name="VisualizerGrid" Grid.Row="0" Height="220" Margin="0,0,0,36" HorizontalAlignment="Stretch">
                            <!-- Rectangles will be populated dynamically in C# -->
                        </Grid>

                        <!-- Cards Area -->
                        <Grid x:Name="CardsAreaGrid" Grid.Row="1" SizeChanged="CardsArea_SizeChanged">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                    
                    <!-- LEFT: Playing Card -->
                    <Grid Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="24" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" x:Name="NowPlayingLabel" Text="Now Playing" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,16"/>
                            
                            <Grid Grid.Row="1" VerticalAlignment="Center" x:Name="WinampContentGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Album Art -->
                                <Border x:Name="WinampAlbumBorder" CornerRadius="8" Background="#222222" Width="130" Height="130" VerticalAlignment="Top" Grid.Column="0" Margin="0,0,16,0">
                                    <Image x:Name="AlbumArtImage" Stretch="UniformToFill"/>
                                </Border>

                                <!-- Metadata -->
                                <StackPanel x:Name="WinampMetadataPanel" Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="TitleText" Text="Waiting for Winamp..." FontSize="22" FontWeight="Bold" TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="ArtistAlbumText" Text="Artist • Album • Year" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,1">
                                        <!-- Quality Badge -->
                                        <Border Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="14" Padding="12,4" HorizontalAlignment="Left" BorderThickness="1" BorderBrush="{ThemeResource ControlElevationBorderBrush}" Margin="0,0,8,0">
                                            <TextBlock x:Name="QualityText" Text="Quality Info" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        </Border>
                                        <!-- Lyrics Button -->
                                        <ToggleButton x:Name="LyricsToggleButton" Style="{StaticResource DefaultToggleButtonStyle}" Click="LyricsToggleButton_Click" CornerRadius="8" Height="32" Width="32" Padding="0" Background="Transparent" BorderThickness="0" IsEnabled="False" ToolTipService.ToolTip="Lyrics">
                                            <Image x:Name="LyricsButtonIcon" Width="18" Height="18" Stretch="Uniform">
                                                <Image.Source>
                                                    <SvgImageSource UriSource="ms-appx:///Assets/lnf_btn.svg" />
                                                </Image.Source>
                                            </Image>
                                        </ToggleButton>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- RIGHT: Discord Preview Card -->
                    <Grid Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="24" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="Discord Status Preview" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,16"/>
                            
                            <Grid Grid.Row="1" VerticalAlignment="Center" x:Name="DiscordContentGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border x:Name="DiscordAlbumBorder" CornerRadius="8" Width="130" Height="130" Grid.Column="0" Margin="0,0,16,0" Background="{ThemeResource ControlFillColorDefaultBrush}">
                                    <Image x:Name="DiscordCoverImage" Stretch="UniformToFill"/>
                                </Border>

                                <StackPanel x:Name="DiscordMetadataPanel" Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="DiscordTitleText" Text="Title" FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="DiscordArtistText" Text="Artist" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="DiscordAlbumText" Text="Album" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                    
                                    <Grid x:Name="DiscordProgressGrid" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Note: Real-time progress isn't sent from Go yet, so we mock it visually -->
                                        <TextBlock x:Name="DiscordStartText" Text="0:00" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <ProgressBar Value="50" Maximum="100" Grid.Column="1" Foreground="{ThemeResource AccentFillColorDefaultBrush}" Background="{ThemeResource ControlFillColorDefaultBrush}" VerticalAlignment="Center" Height="4" CornerRadius="2"/>
                                        <TextBlock x:Name="DiscordLengthText" Text="0:00" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Grid>
                        </Grid>
                    </Grid>
                        </Grid>
                    </Grid>

                
                <!-- Lyrics Panel Wrapper -->
                <Grid Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" x:Name="LyricsPanelWrapper" Width="0" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                    <Grid x:Name="LyricsPanel" Width="350" Margin="24,19,0,0" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Lyrics" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="24,24,24,16"/>
                    
                    <ListView Grid.Row="1" x:Name="LyricsListView" SelectionMode="None" IsItemClickEnabled="False" ContainerContentChanging="LyricsListView_ContainerContentChanging" Padding="24,0,24,24"
                              ScrollViewer.VerticalScrollBarVisibility="Hidden"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ShowsScrollingPlaceholders="False">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Text}" 
                                               FontSize="24" 
                                               TextWrapping="Wrap" 
                                               Margin="0,0,0,24" 
                                               Foreground="{Binding Color}" 
                                               FontWeight="Bold" 
                                               Opacity="{Binding Opacity}"
                                               RenderTransformOrigin="0,0.5">
                                        <TextBlock.RenderTransform>
                                            <ScaleTransform ScaleX="0.9" ScaleY="0.9" />
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                    </ListView>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Controls -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,30" Spacing="10">
                <Button x:Name="StartWinampButton" Content="Start Winamp" Click="StartWinamp_Click" Background="#282828" Foreground="White" FontWeight="SemiBold" Width="140"/>
                <Button x:Name="SyncToggle" Content="Start Sync" Click="SyncToggle_Click" Background="#E2C1B3" Foreground="Black" FontWeight="SemiBold" Width="100"/>
                <Button x:Name="UpdateRpcButton" Content="Update RPC" Click="UpdateRpc_Click" Background="#4A4A4A" Foreground="White" FontWeight="SemiBold" Width="100" IsEnabled="False"/>
                <TextBlock x:Name="StatusText" Text="Disconnected" VerticalAlignment="Center" Foreground="#AAAAAA" Margin="10,0,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
